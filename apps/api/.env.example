# Business API — separate database from apps/auth
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/api_db

# Legacy database url used in data migration script (apps/api/src/scripts/)
SOURCE_DATABASE=


# JWKS endpoint served by apps/auth — used to fetch RS256 public keys at runtime.
# Keys are auto-generated by Better Auth's jwt() plugin and stored in the jwks table.
# No static public key is needed; rotation is handled automatically.
AUTH_JWKS_URL=http://localhost:3001/api/v1/auth/.well-known/jwks.json

# JWT issuer — must match BETTER_AUTH_URL in apps/auth (the `iss` claim in every token)
AUTH_ISSUER=http://localhost:3001

# JWT audience — comma-separated list of expected `aud` values set by apps/auth.
# Must match CLIENT_URL and ADMIN_URL in apps/auth/.env.
AUTH_AUDIENCE=http://localhost:4200

# Trusted origin for CORS (Angular SPA)
CORS=http://localhost:4200

# Server
PORT=3002
NODE_ENV=development
LOG_LEVEL=info

# Sentry error monitoring
SENTRY_DSN=
# Injected at CI build time: GIT_SHA=$(git rev-parse --short HEAD)
GIT_SHA=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

