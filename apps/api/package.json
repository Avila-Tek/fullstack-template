{
	"name": "@repo/api",
	"version": "0.1.0",
	"description": "API Gateway for the backend app IN NEST!",
	"scripts": {
		"build": "nest build ./src && sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist",
		"format": "npx @biomejs/biome format --write",
		"start": "nest start",
		"dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node -r tsconfig-paths/register --require ./dist/telemetry.js dist/main.js",
		"lint": "npx @biomejs/biome lint --write",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "vitest run test",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"sync:countries": "node dist/src/scripts/syncCountries.js"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.0",
		"@nestjs/common": "^11.1.14",
		"@nestjs/core": "^11.1.14",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/terminus": "^11.1.1",
		"@nestjs/throttler": "^6.5.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.72.0",
		"@opentelemetry/exporter-logs-otlp-grpc": "^0.212.0",
		"@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
		"@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
		"@opentelemetry/resources": "^2.6.1",
		"@opentelemetry/sdk-node": "^0.214.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@repo/schemas": "^0.0.0",
		"@repo/utils": "^0.0.0",
		"@sentry/nestjs": "^10.47.0",
		"@thallesp/nestjs-better-auth": "^2.5.4",
		"argon2": "^0.44.0",
		"better-auth": "^1.6.0",
		"dotenv": "^17.2.4",
		"drizzle-orm": "^0.45.1",
		"helmet": "^8.1.0",
		"ioredis": "^5.10.1",
		"jose": "^6.2.1",
		"nestjs-pino": "^4.6.1",
		"nodemailer": "^8.0.5",
		"pg": "^8.18.0",
		"pino": "^10.3.1",
		"pino-opentelemetry-transport": "^3.0.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.2",
		"@eslint/eslintrc": "^3.3.4",
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "^11.1.14",
		"@types/argon2": "^0.15.4",
		"@types/express": "^5.0.6",
		"@types/node": "^22.19.11",
		"@types/pg": "^8.16.0",
		"@types/pino": "^7.0.4",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^4.0.18",
		"drizzle-kit": "^0.31.9",
		"globals": "^16.5.0",
		"pino-pretty": "^13.1.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.2.2",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"roots": [
			"<rootDir>/test"
		],
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"src/**/*.(t|j)s"
		],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node"
	}
}
