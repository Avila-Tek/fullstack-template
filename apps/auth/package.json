{
	"name": "@repo/auth-service",
	"version": "0.1.0",
	"description": "Standalone auth service — NestJS + Better Auth + Drizzle (PostgreSQL)",
	"scripts": {
		"build": "nest build ./src && sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist",
		"format": "npx @biomejs/biome format --write",
		"start": "nest start",
		"dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node --require ./dist/telemetry.js dist/main.js",
		"lint": "npx @biomejs/biome lint --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.5.4",
		"@nestjs/common": "^11.1.14",
		"@nestjs/core": "^11.1.14",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/terminus": "^11.1.1",
		"@nestjs/throttler": "^6.5.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.72.0",
		"@opentelemetry/exporter-logs-otlp-grpc": "^0.212.0",
		"@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
		"@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
		"@opentelemetry/resources": "^2.6.1",
		"@opentelemetry/sdk-node": "^0.214.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@repo/schemas": "^0.0.0",
		"@repo/utils": "^0.0.0",
		"@sentry/nestjs": "^10.47.0",
		"@thallesp/nestjs-better-auth": "^2.5.3",
		"argon2": "^0.44.0",
		"better-auth": "^1.5.4",
		"dotenv": "^17.2.4",
		"drizzle-orm": "^0.45.1",
		"helmet": "^8.1.0",
		"ioredis": "^5.10.0",
		"nestjs-pino": "^4.6.1",
		"nodemailer": "^8.0.2",
		"pg": "^8.18.0",
		"pino": "^10.3.1",
		"pino-opentelemetry-transport": "^3.0.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.2",
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "^11.1.14",
		"@types/express": "^5.0.6",
		"@types/ioredis": "^4.28.10",
		"@types/node": "^22.19.11",
		"@types/nodemailer": "^7.0.11",
		"@types/pg": "^8.16.0",
		"@types/pino": "^7.0.4",
		"@vitest/coverage-v8": "^4.0.18",
		"drizzle-kit": "^0.31.9",
		"pino-pretty": "^13.1.3",
		"source-map-support": "^0.5.21",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18"
	}
}
