{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "baseBranchPatterns": [
        "development"
    ],
    "prHourlyLimit": 2,
    "prConcurrentLimit": 5,
    "packageRules": [
        {
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true,
            "automergeType": "branch",
            "platformAutomerge": false,
            "requiredStatusChecks": null
        },
        {
            "matchUpdateTypes": [
                "major"
            ],
            "automerge": false
        }
    ],
    "ignorePaths": [
        "**/node_modules/**"
    ]
}