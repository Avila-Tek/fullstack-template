{
  "name": "@repo/feature-flags",
  "version": "0.0.0",
  "files": [
    "src/**",
    "dist/**"
  ],
  "exports": {
    "./shared": {
      "types": "./src/shared/index.ts",
      "default": "./dist/shared/index.js"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "default": "./dist/api/index.js"
    },
    "./web": {
